# Traefik Basic Auth (usuario:contraseña codificado en htpasswd)
# IMPORTANTE: Usa comillas simples en el valor para evitar problemas con Docker
# Generar con: ./generate-password.sh admin
TRAEFIK_BASIC_AUTH='admin:$apr1$random$hash'

# Email para certificados SSL Let's Encrypt
LETSENCRYPT_EMAIL=admin@cohortevidaypaz.com.co
